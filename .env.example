# Email Configuration for Event Registration System
# Copy this file to .env and fill in your actual email service details

# SMTP Server Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Email Authentication
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# From Address
EMAIL_FROM=your-email@gmail.com

# Discord Webhook Configuration
# Get webhook URL from Discord Server Settings > Integrations > Webhooks
# Global webhook (fallback for clubs without specific webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Club-specific webhooks (optional - overrides global webhook)
# Each club can have its own Discord channel and webhook
# Format: CLUB_CULTURAL_WEBHOOK_URL, CLUB_TECHNICAL_WEBHOOK_URL, CLUB_SPORTS_WEBHOOK_URL
CLUB_CULTURAL_WEBHOOK_URL=https://discord.com/api/webhooks/CULTURAL_WEBHOOK_ID/CULTURAL_WEBHOOK_TOKEN
CLUB_TECHNICAL_WEBHOOK_URL=https://discord.com/api/webhooks/TECHNICAL_WEBHOOK_ID/TECHNICAL_WEBHOOK_TOKEN
CLUB_SPORTS_WEBHOOK_URL=https://discord.com/api/webhooks/SPORTS_WEBHOOK_ID/SPORTS_WEBHOOK_TOKEN
CLUB_OTHERS_WEBHOOK_URL=https://discord.com/api/webhooks/OTHERS_WEBHOOK_ID/OTHERS_WEBHOOK_TOKEN

# Database Configuration (existing)
MONGODB_URI=mongodb://localhost:27017/event-management

# JWT Secret (existing)
JWT_SECRET=your-jwt-secret-key

# Server Port (existing)
PORT=5000

# Email Setup Instructions:
# 1. For Gmail:
#    - Enable 2-factor authentication on your Gmail account
#    - Generate an App Password: https://myaccount.google.com/apppasswords
#    - Use the App Password as EMAIL_PASS
#    - Set EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587, EMAIL_SECURE=false
#
# 2. For Outlook/Hotmail:
#    - Set EMAIL_HOST=smtp-mail.outlook.com
#    - Set EMAIL_PORT=587, EMAIL_SECURE=false
#
# 3. For other email services:
#    - Check your email provider's SMTP settings
#    - Update EMAIL_HOST, EMAIL_PORT, EMAIL_SECURE accordingly
#
# 4. For development/testing:
#    - You can use a service like Ethereal (https://ethereal.email/)
#    - Or Mailtrap (https://mailtrap.io/) for testing emails

# Discord Webhook Setup Instructions:
# 1. Go to your Discord server
# 2. Click on Server Settings > Integrations
# 3. Click "Create Webhook" or use existing webhook
# 4. Copy the Webhook URL
# 5. Set DISCORD_WEBHOOK_URL in your .env file
# 6. Customize webhook name and avatar in Discord if desired
#
# Note: If DISCORD_WEBHOOK_URL is not set, Discord announcements will be skipped
# without affecting event creation functionality.
